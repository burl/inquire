# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[*.{js,json,go,yaml,yml}]
charset = utf-8

[*.yaml,*.yml]
indent_style = space
indent_size = 2

[*.json]
indent_size = 2
indent_style = space

[*.js]
indent_size = 4
indent_style = space

[Makefile,*.mk]
indent_style = tab
indent_size = 4

[*.go]
indent_style = tab
indent_size = 4
